# Copy to .env.local and add your key:
#   cp .env.example .env.local
#
# Get a key: https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-your-key-here

EMBEDDING_MODEL=text-embedding-3-small
RANKER_MODEL=gpt-4o-mini
INTENT_MODEL=gpt-4o-mini
PLANNER_MODEL=gpt-4o-mini

# local: self-hosted/BYOK-friendly, no credit metering.
# open: hosted shared-key mode, requires a credits backend.
APP_MODE=local
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ALLOWED_ORIGIN=https://your-domain.example

# Optional admin/feedback settings
# Set before deploying if /admin/feedback should be private.
ADMIN_TOKEN=change-me
SESSION_SECRET=replace-with-a-long-random-secret

# Feedback storage.
# Local default writes to data/feedback.jsonl. NOTE: this does NOT work on
# Vercel/serverless — the filesystem is read-only, so file writes fail. For any
# serverless deploy, use FEEDBACK_STORE=webhook and point it at an endpoint you
# control (e.g. a Supabase function, a Google Sheet webhook, or your own API).
FEEDBACK_STORE=file

# Serverless/Vercel: send feedback to an external endpoint instead of a file.
# FEEDBACK_STORE=webhook
# FEEDBACK_WEBHOOK_URL=https://example.com/auto-feedback
# FEEDBACK_WEBHOOK_SECRET=optional-shared-secret

# Hosted/open-mode credit metering.
# Run db/credits.sql in Supabase, then set these in the server environment.
# APP_MODE=open
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# FREE_CREDITS=30
# CREDITS_BACKEND=memory # local development only; blocked in production

# Shared rate limits for multi-instance/serverless deployments.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# Optional Stripe top-ups.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# CREDITS_PER_PURCHASE=100
